# Safe application defaults. Live flags are intentionally independent.
TRADING_MODE=PAPER
LIVE_EQUITIES_ENABLED=false
LIVE_CRYPTO_ENABLED=false
AUTONOMOUS_EXECUTION_ENABLED=false
QUANT_DESK_DATABASE_URL=sqlite:///./quant_desk.db
QUANT_DESK_REDIS_URL=
QUANT_DESK_API_TOKEN=replace_with_a_long_random_local_token
TRADINGVIEW_WEBHOOK_SECRET=replace_with_a_long_random_webhook_secret
TRADINGVIEW_MAX_BODY_BYTES=32768
TRADINGVIEW_MAX_AGE_SECONDS=60

# Existing Alpaca PAPER compatibility tools.
# Every TradingClient in bots/ remains hard-locked to paper=True.
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Safety controls. Keep DRY_RUN=true until several scheduled runs look correct.
DRY_RUN=true
ALWAYS_NOTIFY=true

# Exit manager thresholds.
STOP_PCT=0.15
TAKE_PCT=0.40
USE_TAKE_PROFIT=true

# Optional notifications. Leave blank to disable.
SLACK_WEBHOOK_URL=
EMAIL_TO=
EMAIL_FROM=
EMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Optional local log overrides.
LOG_FILE=

# Robinhood Trading MCP is authenticated through its official interactive
# user-facing flow. No Robinhood login credentials belong in this file.
ROBINHOOD_AGENTIC_EXPECTED_ACCOUNT_ID=
ROBINHOOD_AGENTIC_BRIDGE_URL=

# Official Robinhood Crypto Trading API. Leave unset during development.
# The private key must be base64-encoded Ed25519 material supplied through a
# secure environment/secret manager, never committed.
ROBINHOOD_CRYPTO_API_KEY=
ROBINHOOD_CRYPTO_PRIVATE_KEY_B64=
ROBINHOOD_CRYPTO_EXPECTED_ACCOUNT_ID=
