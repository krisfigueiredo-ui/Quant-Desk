# Copy this file to .env and add PAPER credentials from
# alpaca.markets -> Paper Trading -> API Keys.
# Every TradingClient in this repository is hard-locked to paper=True.
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Safety controls. Keep DRY_RUN=true until several scheduled runs look correct.
DRY_RUN=true
ALWAYS_NOTIFY=true

# Exit manager thresholds.
STOP_PCT=0.15
TAKE_PCT=0.40
USE_TAKE_PROFIT=true

# Optional notifications. Leave blank to disable.
SLACK_WEBHOOK_URL=
EMAIL_TO=
EMAIL_FROM=
EMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Optional local log overrides.
LOG_FILE=
