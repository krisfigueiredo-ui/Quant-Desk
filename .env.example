# Copy to .env and fill in. PAPER keys only — get them at alpaca.markets
# (Paper Trading -> API Keys). Live keys won't authenticate against the paper
# endpoint, and every client in this repo is hard-locked to paper=True.
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Safety: "true" logs intended orders without submitting anything.
# Flip to "false" only after you've watched a few dry runs.
DRY_RUN=true

# Optional notifications — leave blank to disable.
SLACK_WEBHOOK_URL=
EMAIL_TO=
EMAIL_FROM=
EMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Ping even on no-trade days ("silence means something broke").
ALWAYS_NOTIFY=true
