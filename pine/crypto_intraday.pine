//@version=6
indicator("Quant Desk Crypto Intraday Input v1", overlay=true)

// Spot research input only. The server allowlist, venue capability discovery,
// market-data confirmation, typed review, and deterministic risk veto still apply.
breakoutLength = input.int(48, "Breakout bars", minval=12)
volumeLength = input.int(48, "Volume average", minval=12)
priorHigh = ta.highest(high, breakoutLength)[1]
volumeRatio = volume / ta.sma(volume, volumeLength)
longSignal = close > priorHigh and volumeRatio > 1.3

plot(priorHigh, "Prior breakout high", color=color.new(color.aqua, 15))

if longSignal and barstate.isconfirmed
    signalId = syminfo.tickerid + "-" + timeframe.period + "-" + str.tostring(time_close)
    observedAt = str.format_time(time_close, "yyyy-MM-dd'T'HH:mm:ss'Z'", "UTC")
    expiresAt = str.format_time(time_close + 60000, "yyyy-MM-dd'T'HH:mm:ss'Z'", "UTC")
    payload = '{"schema_version":"1.0.0","signal_id":"' + signalId +
      '","strategy_id":"crypto-intraday-breakout-v1","asset_class":"CRYPTO","symbol":"' +
      syminfo.basecurrency + '-USD","side":"BUY","timeframe":"' + timeframe.period +
      '","signal_timestamp":"' + observedAt + '","expires_at":"' + expiresAt +
      '","indicator_values":{"prior_high":' + str.tostring(priorHigh) +
      ',"volume_ratio":' + str.tostring(volumeRatio) + '}}'
    alert(payload, alert.freq_once_per_bar_close)

alertcondition(longSignal, "Quant Desk crypto candidate", "Use an Any alert() function call alert.")
